{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Quarto: Preview (No Browser)",
            "type": "shell",
            "command": "quarto",
            "args": [
                "preview",
                "${file}",
                "--no-browser"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false,
                "clear": true,
                "close": false
            },
            "problemMatcher": [],
            "isBackground": false
        }
    ]
}